{
  "id": "kiro",
  "platformId": "kiro",
  "version": "0.26.9",
  "apiVersion": 1,
  "minCoreVersion": "0.26.5",
  "displayName": "Kiro",
  "entry": "runtime/index.json",
  "packageMode": "hotUpdate",
  "installKind": "sidecarAdapter",
  "adapter": {
    "protocol": "http-json-v1",
    "entry": "adapter/macos/cockpit-kiro-adapter",
    "macosEntry": "adapter/macos/cockpit-kiro-adapter",
    "windowsEntry": "adapter/windows/cockpit-kiro-adapter.exe",
    "linuxEntry": "adapter/linux/cockpit-kiro-adapter",
    "methods": [
      "health.check",
      "accounts.list",
      "accounts.current",
      "accounts.keepaliveDue",
      "accounts.delete",
      "accounts.deleteMany",
      "accounts.importJson",
      "accounts.importLocal",
      "accounts.addToken",
      "accounts.export",
      "accounts.indexPath",
      "accounts.refresh",
      "accounts.refreshAll",
      "accounts.updateTags",
      "quota.alertPayload",
      "oauth.start",
      "oauth.complete",
      "oauth.cancel",
      "oauth.submitCallbackUrl",
      "oauth.restorePendingListener",
      "switch.inject",
      "instances.store.get",
      "instances.store.replace",
      "instance.getDefaults",
      "instance.list",
      "instance.create",
      "instance.update",
      "instance.delete",
      "instance.start",
      "instance.stop",
      "instance.closeAll",
      "instance.openWindow",
      "runtime.detectLaunchPath",
      "runtime.status",
      "runtime.startDefault",
      "runtime.stopDefault",
      "runtime.restartDefault",
      "runtime.focusDefault"
    ]
  },
  "ui": {
    "protocol": "react-remote-esm-v1",
    "entry": "ui/remoteEntry.js",
    "style": "ui/style.css",
    "exports": [
      "mount",
      "unmount"
    ]
  },
  "capabilities": [
    "accounts",
    "oauth",
    "switch",
    "quota",
    "runtime",
    "instances"
  ],
  "changelog": [
    {
      "version": "0.26.9",
      "date": "2026-06-30",
      "notes": [
        "Fixes the Windows adapter startup crash when an unfinished Kiro OAuth session is present.",
        "The adapter now completes its bootstrap handshake before restoring pending OAuth listeners, and restores them inside a Tokio runtime context."
      ],
      "locales": {
        "zh-CN": {
          "notes": [
            "修复 Windows 上存在未完成 Kiro OAuth 会话时 adapter 启动崩溃的问题。",
            "adapter 现在会先完成启动握手，再在 Tokio runtime 上下文中恢复 pending OAuth 监听。"
          ]
        },
        "zh-TW": {
          "notes": [
            "修復 Windows 上存在未完成 Kiro OAuth 工作階段時 adapter 啟動崩潰的問題。",
            "adapter 現在會先完成啟動握手，再於 Tokio runtime 上下文中恢復 pending OAuth 監聽。"
          ]
        }
      }
    },
    {
      "version": "0.26.8",
      "date": "2026-06-30",
      "notes": [
        "Adds immutable platform package version history metadata so users can install, reinstall, update, or roll back to published package versions.",
        "Refreshes the platform package artifact for the main channel without replacing any previously published zip."
      ],
      "locales": {
        "zh-CN": {
          "notes": [
            "新增不可变的平台包版本历史元数据，用户可以安装、重新安装、更新或回退到已发布的平台包版本。",
            "刷新主通道平台包产物，同时不替换任何已发布过的旧 zip。"
          ]
        },
        "zh-TW": {
          "notes": [
            "新增不可變的平台包版本歷史中繼資料，使用者可以安裝、重新安裝、更新或回復到已發布的平台包版本。",
            "刷新主通道平台包產物，同時不替換任何已發布過的舊 zip。"
          ]
        }
      }
    },
    {
      "version": "0.26.7",
      "date": "2026-06-23",
      "notes": [
        "Kiro account overview, multi-instance tabs, OAuth, switching, quota refresh, and page interactions are now supplied by the Kiro platform package.",
        "Core Shell keeps only Kiro platform lifecycle controls, runtime gate, Host API, and adapter runner."
      ]
    }
  ],
  "contributions": {
    "platforms": [
      {
        "id": "kiro",
        "label": "Kiro",
        "labelKey": "nav.kiro",
        "iconKey": "kiro",
        "page": "kiro"
      }
    ],
    "dataPaths": [
      "kiro_accounts.json",
      "kiro_accounts",
      "kiro_instances.json"
    ],
    "localStorageKeys": [
      "agtools.kiro.accounts.cache",
      "agtools.kiro.current_account_id",
      "agtools.kiro.flow_notice_collapsed",
      "agtools.kiro.instances.cache"
    ],
    "nativeBoundaries": []
  }
}
